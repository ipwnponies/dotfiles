{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "build": {
      "permission": {
        "bash": {
          "bd list*": "allow",
          "bd ready": "allow",
          "bd show": "allow",
          "bd show *": "allow",
          "fd *": "allow",
          "fd .": "allow",
          "git branch*": "allow",
          "git diff*": "allow",
          "git log*": "allow",
          "git rev-parse --abbrev-ref HEAD": "allow",
          "git rev-parse --is-inside-work-tree": "allow",
          "git rev-parse --show-toplevel": "allow",
          "git rev-parse HEAD": "allow",
          "git show*": "allow",
          "git status": "allow",
          "git status --short": "allow",
          "go test": "allow",
          "rg *": "allow"
        },
        "glob": "allow",
        "grep": "allow",
        "read": "allow",
        "task": {
          "permtest": "allow"
        }
      }
    },
    "committer": {
      "permission": {
        "bash": {
          "git add *": "allow",
          "git commit --amend -m *": "ask",
          "git commit -F *": "allow",
          "git commit -m *": "allow",
          "git diff": "allow",
          "git diff *": "allow",
          "git diff --cached": "allow",
          "git diff --cached *": "allow",
          "git log --oneline": "allow",
          "git log --oneline *": "allow",
          "git push*": "deny",
          "git rebase*": "deny",
          "git reset*": "deny",
          "git restore --staged *": "ask",
          "git status": "allow",
          "git status *": "allow"
        },
        "edit": "deny",
        "webfetch": "deny"
      }
    },
    "implementer": {
      "permission": {
        "bash": {
          "bd list*": "allow",
          "bd ready": "allow",
          "bd show *": "allow",
          "bd sync --flush-only": "allow",
          "bd update *": "allow",
          "bun test*": "allow",
          "cargo test*": "allow",
          "eslint *": "allow",
          "git checkout *": "deny",
          "git diff*": "allow",
          "git log*": "allow",
          "git push*": "deny",
          "git rebase*": "deny",
          "git reset*": "deny",
          "git status*": "allow",
          "go test*": "allow",
          "make lint*": "allow",
          "make test*": "allow",
          "mypy *": "allow",
          "npm test*": "allow",
          "pnpm test*": "allow",
          "pytest*": "allow",
          "python -m pytest*": "allow",
          "ruff *": "allow",
          "yarn test*": "allow"
        },
        "edit": "allow",
        "glob": "allow",
        "grep": "allow",
        "read": "allow"
      }
    },
    "intern": {
      "permission": {
        "*": "deny",
        "task": {
          "*": "deny",
          "orchestrator": "allow"
        }
      }
    },
    "orchestrator": {
      "permission": {
        "*": "deny",
        "bash": {
          "bd blocked": "allow",
          "bd close *": "allow",
          "bd create *": "allow",
          "bd dep add *": "allow",
          "bd doctor": "allow",
          "bd list*": "allow",
          "bd ready": "allow",
          "bd show *": "allow",
          "bd stats": "allow",
          "bd sync --flush-only": "allow",
          "bd update *": "allow"
        },
        "task": {
          "*": "deny",
          "implementer": "allow",
          "qa": "allow",
          "researcher": "allow",
          "reviewer": "allow"
        }
      }
    },
    "qa": {
      "permission": {
        "bash": {
          "bd list*": "allow",
          "bd ready": "allow",
          "bd show *": "allow",
          "bun test*": "allow",
          "cargo test*": "allow",
          "go test*": "allow",
          "make lint*": "allow",
          "make test*": "allow",
          "npm test*": "allow",
          "pnpm test*": "allow",
          "pytest*": "allow",
          "python -m pytest*": "allow",
          "yarn test*": "allow"
        },
        "edit": "deny"
      }
    },
    "researcher": {
      "permission": {
        "bash": {
          "ansible *": "deny",
          "bd blocked": "allow",
          "bd create *": "allow",
          "bd dep add *": "allow",
          "bd doctor": "allow",
          "bd list*": "allow",
          "bd ready": "allow",
          "bd show *": "allow",
          "bd stats": "allow",
          "bd sync --flush-only": "allow",
          "bd update *": "allow",
          "bun add*": "deny",
          "chmod *": "deny",
          "chown *": "deny",
          "cp *": "deny",
          "docker *": "deny",
          "du *": "allow",
          "fd *": "allow",
          "find *": "allow",
          "git add*": "deny",
          "git branch*": "allow",
          "git checkout*": "deny",
          "git commit*": "deny",
          "git diff*": "allow",
          "git log*": "allow",
          "git merge*": "deny",
          "git pull*": "deny",
          "git push*": "deny",
          "git rebase*": "deny",
          "git reset*": "deny",
          "git rev-parse*": "allow",
          "git show*": "allow",
          "git status*": "allow",
          "jq *": "allow",
          "kubectl *": "deny",
          "ls*": "allow",
          "mv *": "deny",
          "npm install*": "deny",
          "pip install*": "deny",
          "pnpm install*": "deny",
          "rg *": "allow",
          "rm *": "deny",
          "terraform *": "deny",
          "uv pip install*": "deny",
          "wc *": "allow",
          "yarn add*": "deny",
          "yq *": "allow"
        },
        "edit": "deny",
        "glob": "allow",
        "grep": "allow",
        "read": "allow"
      }
    },
    "reviewer": {
      "permission": {
        "bash": {
          "fd *": "allow",
          "git diff*": "allow",
          "git log*": "allow",
          "git show *": "allow",
          "git status*": "allow",
          "ls*": "allow",
          "rg *": "allow"
        },
        "edit": "deny",
        "glob": "allow",
        "read": "allow"
      }
    }
  },
  "permission": {
    "*": "ask",
    "glob": "allow"
  }
}
