{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "build": {
      "permission": {
        "bash": {
          "bd * --help": "allow",
          "bd create *": "allow",
          "bd dep add *": "allow",
          "bd search *": "allow",
          "bd update *": "allow",
          "git branch": "allow",
          "git branch *": "allow"
        },
        "skill": "allow",
        "task": {
          "*": "deny",
          "committer": "allow",
          "orchestrator": "allow",
          "reviewer": "allow"
        },
        "todoread": "allow",
        "todowrite": "allow"
      }
    },
    "committer": {
      "hidden": false,
      "model": "{env:OPENCODE_MODEL_LIGHT}",
      "permission": {
        "bash": {
          "cat *": "deny",
          "git add *": "allow",
          "git commit *": "allow",
          "git commit --amend -m *": "ask",
          "git diff": "allow",
          "git diff *": "allow",
          "git diff --cached *": "allow",
          "git log": "allow",
          "git log *": "allow",
          "git push*": "deny",
          "git rebase*": "deny",
          "git reset*": "deny",
          // Commit uses git stash to handle staging targeted files. Opencode agent not capable to staging hunks.
          "git stash *": "allow",
          "git status": "allow",
          "git status *": "allow",
          // Prevent shell-based directory discovery; the agent should rely on scoped file tools.
          "ls *": "deny"
        },
        "edit": "deny",
        "question": "allow",
        "read": {
          "*": "deny",
          ".config/opencode/agents/committer.md": "allow"
        },
        "webfetch": "deny"
      },
      "steps": 6,
      "temperature": 0
    },
    "fixer": {
      "hidden": true,
      "model": "{env:OPENCODE_MODEL_DEEP}",
      "permission": {
        "bash": {
          "bd update *": "allow",
          "bun test*": "allow",
          "cargo test*": "allow",
          "eslint *": "allow",
          "git checkout *": "deny",
          "git push*": "deny",
          "git rebase*": "deny",
          "git reset*": "deny",
          "go test*": "allow",
          "make lint*": "allow",
          "make test*": "allow",
          "mypy *": "allow",
          "npm test*": "allow",
          "pnpm test*": "allow",
          "pytest*": "allow",
          "python -m pytest*": "allow",
          "ruff *": "allow",
          "yarn test*": "allow"
        },
        "edit": "allow",
        "task": {
          "*": "deny",
          "reviewer_impl": "allow"
        },
        "write": "deny"
      },
      "steps": 8,
      "temperature": 0.1
    },
    "implementer": {
      "hidden": false,
      "model": "{env:OPENCODE_MODEL_DEEP}",
      "permission": {
        "bash": {
          "bd update *": "allow",
          "bun test*": "allow",
          "cargo test*": "allow",
          "eslint *": "allow",
          "git checkout *": "deny",
          "git push*": "deny",
          "git rebase*": "deny",
          "git reset*": "deny",
          "go test*": "allow",
          "make lint*": "allow",
          "make test*": "allow",
          "mypy *": "allow",
          "npm test*": "allow",
          "pnpm test*": "allow",
          "pytest*": "allow",
          "python -m pytest*": "allow",
          "ruff *": "allow",
          "yarn test*": "allow"
        },
        "edit": "allow"
      },
      "steps": 20,
      "temperature": 0.15
    },
    "orchestrator": {
      "hidden": false,
      "model": "{env:OPENCODE_MODEL_LIGHT}",
      "permission": {
        "*": "deny",
        "bash": {
          "bd blocked *": "allow",
          "bd close *": "allow",
          "bd count *": "allow",
          "bd create *": "allow",
          "bd dep add *": "allow",
          "bd doctor *": "allow",
          "bd list *": "allow",
          "bd query *": "allow",
          "bd ready *": "allow",
          "bd show *": "allow",
          "bd stats *": "allow",
          "bd status *": "allow",
          "bd update *": "allow"
        },
        "glob": {
          "*": "deny",
          // Have space for orchestrator to dump artifacts, such as research. Or other handoff items.
          ".opencode/design/**": "allow"
        },
        "grep": "allow",
        "list": {
          "*": "deny",
          ".opencode/design/**": "allow"
        },
        "question": "allow",
        "read": {
          "*": "deny",
          ".opencode/design/**": "allow"
        },
        "task": {
          "*": "deny",
          "committer": "allow",
          "fixer": "allow",
          "implementer": "allow",
          "patch_fixer": "allow",
          "patch_implementer": "allow",
          "patch_reviewer": "allow",
          "qa": "allow",
          "researcher": "allow",
          "reviewer": "allow",
          "reviewer_impl": "allow"
        },
        "todoread": "allow",
        "todowrite": "allow",
        "write": {
          "*": "deny",
          ".opencode/design/**": "allow"
        }
      },
      "temperature": 0.1
    },
    "patch_fixer": {
      "hidden": false,
      "mode": "subagent",
      "model": "{env:OPENCODE_MODEL_LIGHT}",
      "permission": {
        "bash": {
          "bd update *": "allow",
          "bun test*": "allow",
          "cargo test*": "allow",
          "eslint *": "allow",
          "git checkout *": "deny",
          "git push*": "deny",
          "git rebase*": "deny",
          "git reset*": "deny",
          "go test*": "allow",
          "make lint*": "allow",
          "make test*": "allow",
          "mypy *": "allow",
          "npm test*": "allow",
          "pnpm test*": "allow",
          "pytest*": "allow",
          "python -m pytest*": "allow",
          "ruff *": "allow",
          "yarn test*": "allow"
        },
        "edit": "allow",
        "task": {
          "*": "deny",
          "patch_reviewer": "allow"
        }
      },
      "prompt": "{file:./agents/fixer.md}",
      "steps": 6,
      "temperature": 0.1
    },
    "patch_implementer": {
      "hidden": false,
      "mode": "subagent",
      "model": "{env:OPENCODE_MODEL_LIGHT}",
      "permission": {
        "bash": {
          "bd update *": "allow",
          "bun test*": "allow",
          "cargo test*": "allow",
          "eslint *": "allow",
          "git checkout *": "deny",
          "git push*": "deny",
          "git rebase*": "deny",
          "git reset*": "deny",
          "go test*": "allow",
          "make lint*": "allow",
          "make test*": "allow",
          "mypy *": "allow",
          "npm test*": "allow",
          "pnpm test*": "allow",
          "pytest*": "allow",
          "python -m pytest*": "allow",
          "ruff *": "allow",
          "yarn test*": "allow"
        },
        "edit": "allow"
      },
      "prompt": "{file:./agents/implementer.md}",
      "steps": 6,
      "temperature": 0.1
    },
    "patch_reviewer": {
      "hidden": false,
      "mode": "subagent",
      "model": "{env:OPENCODE_MODEL_LIGHT}",
      "permission": {
        "edit": "deny",
        "task": {
          "*": "deny",
          "patch_fixer": "allow"
        }
      },
      "prompt": "{file:./agents/reviewer_impl.md}",
      "steps": 6,
      "temperature": 0.1
    },
    "plan": {
      "permission": {
        "bash": {
          "bd search *": "allow",
          "git branch": "allow",
          "git branch *": "allow",
          "git diff": "allow",
          "git diff *": "allow",
          "git log": "allow",
          "git log *": "allow",
          "git rev-parse *": "allow",
          "git show": "allow",
          "git show *": "allow",
          "git status": "allow",
          "git status *": "allow"
        },
        "skill": {
          "*": "deny",
          "design": "allow"
        },
        "task": {
          "*": "deny",
          "orchestrator": "allow",
          "researcher": "allow",
          "reviewer": "allow"
        },
        "todoread": "allow",
        "todowrite": "allow"
      }
    },
    "qa": {
      "hidden": true,
      "model": "{env:OPENCODE_MODEL_LIGHT}",
      "permission": {
        "bash": {
          "bun test*": "allow",
          "cargo test*": "allow",
          "go test*": "allow",
          "make lint*": "allow",
          "make test*": "allow",
          "npm test*": "allow",
          "pnpm test*": "allow",
          "pytest*": "allow",
          "python -m pytest*": "allow",
          "yarn test*": "allow"
        },
        "edit": "deny",
        "write": "deny"
      },
      "steps": 12,
      "temperature": 0.05
    },
    "researcher": {
      "hidden": true,
      "model": "{env:OPENCODE_MODEL_DEEP}",
      "permission": {
        "bash": {
          "ansible *": "deny",
          "bd blocked *": "allow",
          "bd create *": "allow",
          "bd dep add *": "allow",
          "bd doctor *": "allow",
          "bd stats *": "allow",
          "bd update *": "allow",
          "bun add*": "deny",
          // Keep the researcher safely read-only even when shell access is available.
          "chmod *": "deny",
          "chown *": "deny",
          "cp *": "deny",
          "docker *": "deny",
          "du *": "allow",
          "git add*": "deny",
          "git branch*": "deny",
          "git checkout*": "deny",
          "git commit*": "deny",
          "git diff*": "allow",
          "git merge*": "deny",
          "git pull*": "deny",
          "git push*": "deny",
          "git rebase*": "deny",
          "git reset*": "deny",
          "git rev-parse*": "allow",
          "git show*": "allow",
          "git status*": "allow",
          "jq *": "allow",
          "kubectl *": "deny",
          "mv *": "deny",
          "npm install*": "deny",
          "pip install*": "deny",
          "pnpm install*": "deny",
          "rm *": "deny",
          "terraform *": "deny",
          "uv pip install*": "deny",
          "wc *": "allow",
          "yarn add*": "deny",
          "yq *": "allow"
        },
        "edit": "deny",
        "task": {
          "*": "deny",
          "reviewer": "allow"
        }
      },
      "steps": 18,
      "temperature": 0.25
    },
    "reviewer": {
      "hidden": true,
      "model": "{env:OPENCODE_MODEL_DEEP}",
      "permission": {
        "bash": {
          "git diff*": "allow",
          "git status*": "allow"
        },
        "edit": "deny",
        "task": {
          "*": "deny",
          "researcher": "allow"
        }
      },
      "steps": 10,
      "temperature": 0.25
    },
    "reviewer_impl": {
      "hidden": true,
      "model": "{env:OPENCODE_MODEL_DEEP}",
      "permission": {
        "bash": {
          "git diff*": "allow",
          "git status*": "allow"
        },
        "edit": "deny",
        "task": {
          "*": "deny",
          "fixer": "allow"
        }
      },
      "steps": 10,
      "temperature": 0.2
    }
  },
  "model": "{env:OPENCODE_MODEL_DEEP}",
  "permission": {
    "*": "ask",
    "bash": {
      "* --help": "allow",
      "bd count *": "allow",
      "bd list *": "allow",
      "bd onboard": "allow",
      "bd prime": "allow",
      "bd query *": "allow",
      "bd ready *": "allow",
      "bd show": "allow",
      "bd show *": "allow",
      "bd status *": "allow",
      "git diff": "allow",
      "git diff *": "allow",
      "git log": "allow",
      "git log *": "allow",
      "git rev-parse *": "allow",
      "git show": "allow",
      "git show *": "allow",
      "git status": "allow",
      "git status *": "allow"
    },
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "read": "allow",
    "skill": {
      // These workflows are only meant for interactive user to invoke. Deny so that agents don't misinterpret them as
      // useful for agent instruction.
      "commit": "deny",
      "design": "deny",
      "implement": "deny",
      "patch": "deny"
    }
  },
  "small_model": "{env:OPENCODE_MODEL_LIGHT}"
}
